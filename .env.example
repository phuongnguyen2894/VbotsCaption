# Ollama API endpoint — run Ollama locally
# Download: https://ollama.ai
# Start: ollama serve
# Default: http://localhost:11434
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=orca-mini

# Vercel KV — added automatically when you connect a KV database in the Vercel dashboard
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
